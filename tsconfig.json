{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "DOM",
      "DOM.Iterable",
      "ES2022"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "src/*"
      ]
    },
    "strictNullChecks": true
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    "app/**/*.ts",
    "app/**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "playwright-fixture.ts",
    "playwright.config.ts",
    "vitest.config.ts",
    "vite.config.ts",
    "src/main.tsx",
    "src/App.tsx",
    "src/vite-env.d.ts",
    "src/pages/**/*",
    "src/pages",
    "src/test/**/*",
    "src/test",
    "playwright/**/*",
    "src/components/Layout.tsx",
    "src/components/NavLink.tsx"
  ]
}
